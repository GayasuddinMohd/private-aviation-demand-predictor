    "import pandas as pd\n",
    "import numpy as np\n",
    "import random\n",
    "\n",
    "# Load the data from Notebook 1\n",
    "df = pd.read_csv(\"flights_raw.csv\")\n",
    "print(f\"✅ Loaded {len(df)} flights from flights_raw.csv\")\n",
    "\n",
    "# ── Mock API Enrichment (simulates AviationStack response) ────────────────\n",
    "# In production, you'd call: api.aviationstack.com/v1/flights\n",
    "# We simulate the same fields the API would return\n",
    "\n",
    "random.seed(99)\n",
    "np.random.seed(99)\n",
    "\n",
    "airlines = [\n",
    "    \"NetJets\", \"Wheels Up\", \"VistaJet\", \"Air Charter\",\n",
    "    \"Flexjet\", \"Sentient Jet\", \"XOJET\", \"Priester Aviation\"\n",
    "]\n",
    "\n",
    "flight_statuses = [\"landed\", \"landed\", \"landed\", \"scheduled\", \"en-route\", \"cancelled\"]\n",
    "\n",
    "def mock_api_enrich(row):\n",
    "    \"\"\"Simulates what AviationStack API would return for each flight.\"\"\"\n",
    "    return {\n",
    "        \"airline_name\":   random.choice(airlines),\n",
    "        \"flight_status\":  random.choice(flight_statuses),\n",
    "        \"dep_delay_min\":  max(0, int(np.random.normal(loc=8, scale=15))),\n",
    "        \"passenger_cap\":  random.choice([6, 8, 9, 12, 14, 16]),\n",
    "        \"charter_type\":   random.choice([\"on-demand\", \"fractional\", \"jet-card\"]),\n",
    "    }\n",
    "\n",
    "print(\"\\n⏳ Enriching flights (simulating API calls)...\")\n",
    "enriched_rows = df.apply(mock_api_enrich, axis=1, result_type=\"expand\")\n",
    "df_enriched = pd.concat([df, enriched_rows], axis=1)\n",
    "\n",
    "# ── Summary stats ──────────────────────────────────────────────────────────\n",
    "print(f\"\\n✅ Enrichment complete! Shape: {df_enriched.shape}\")\n",
    "print(\"\\n📊 Sample enriched data:\")\n",
    "print(df_enriched[[\"flight_number\",\"origin\",\"destination\",\n",
    "                    \"airline_name\",\"flight_status\",\n",
    "                    \"dep_delay_min\",\"charter_type\"]].head(10))\n",
    "\n",
    "print(\"\\n📊 Charter type distribution:\")\n",
    "print(df_enriched[\"charter_type\"].value_counts())\n",
    "\n",
    "print(\"\\n📊 Avg departure delay by airline:\")\n",
    "print(df_enriched.groupby(\"airline_name\")[\"dep_delay_min\"]\n",
    "      .mean().round(1).sort_values(ascending=False))\n",
    "\n",
    "# Save for Notebook 3\n",
    "df_enriched.to_csv(\"flights_enriched.csv\", index=False)\n",
    "print(\"\\n💾 Saved to flights_enriched.csv\")"
   ]
