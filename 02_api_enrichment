    "API_KEY = \"680de96145549bd4c98dc405e8e2a4f4\"  # your key\n",
    "\n",
    "# We'll only call for unique routes to save API calls\n",
    "unique_routes = df[[\"origin\", \"destination\"]].drop_duplicates().head(20)\n",
    "print(f\"Unique routes to enrich: {len(unique_routes)}\")\n",
    "\n",
    "enriched_routes = []\n",
    "\n",
    "for _, row in unique_routes.iterrows():\n",
    "    # Convert ICAO (KLAX) → IATA (LAX) by removing the K\n",
    "    dep_iata = row[\"origin\"].replace(\"K\", \"\", 1)\n",
    "    arr_iata = row[\"destination\"].replace(\"K\", \"\", 1)\n",
    "    \n",
    "    try:\n",
    "        response = requests.get(\n",
    "            \"http://api.aviationstack.com/v1/flights\",\n",
    "            params={\n",
    "                \"access_key\": API_KEY,\n",
    "                \"dep_iata\": dep_iata,\n",
    "                \"arr_iata\": arr_iata,\n",
    "                \"limit\": 1\n",
    "            },\n",
    "            timeout=10\n",
    "        )\n",
    "        data = response.json()\n",
    "        \n",
    "        if \"data\" in data and data[\"data\"]:\n",
    "            flight = data[\"data\"][0]\n",
    "            enriched_routes.append({\n",
    "                \"origin\": row[\"origin\"],\n",
    "                \"destination\": row[\"destination\"],\n",
    "                \"airline_name\": flight.get(\"airline\", {}).get(\"name\", \"Charter/Unknown\"),\n",
    "                \"flight_status\": flight.get(\"flight_status\", \"unknown\"),\n",
    "                \"aircraft_icao\": flight.get(\"aircraft\", {}).get(\"icao\", \"Unknown\") if flight.get(\"aircraft\") else \"Unknown\",\n",
    "                \"dep_airport\": flight.get(\"departure\", {}).get(\"airport\", \"Unknown\"),\n",
    "                \"arr_airport\": flight.get(\"arrival\", {}).get(\"airport\", \"Unknown\"),\n",
    "            })\n",
    "            print(f\"✅ {row['origin']} → {row['destination']}: enriched\")\n",
    "        else:\n",
    "            print(f\"⚠️  {row['origin']} → {row['destination']}: no data returned\")\n",
    "            enriched_routes.append({\n",
    "                \"origin\": row[\"origin\"],\n",
    "                \"destination\": row[\"destination\"],\n",
    "                \"airline_name\": \"Charter/Unknown\",\n",
    "                \"flight_status\": \"unknown\",\n",
    "                \"aircraft_icao\": \"Unknown\",\n",
    "                \"dep_airport\": \"Unknown\",\n",
    "                \"arr_airport\": \"Unknown\",\n",
    "            })\n",
    "        \n",
    "        time.sleep(1)  # Stay within free tier rate limits\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"❌ Error on {row['origin']} → {row['destination']}: {e}\")\n",
    "\n",
    "df_enriched_routes = pd.DataFrame(enriched_routes)\n",
    "print(f\"\\nEnriched {len(df_enriched_routes)} routes\")\n",
    "print(df_enriched_routes)"
   ]
